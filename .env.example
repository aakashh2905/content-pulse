PORT=3000
NODE_ENV=development
MAX_REQUEST_BODY_BYTES=1000000
MAX_ACTIVE_RUNS=1
SCHEDULER_INTERVAL_MS=60000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TIMEOUT_MS=60000
OPENAI_TRANSCRIPTION_TIMEOUT_MS=60000
OPENAI_TRANSCRIPTION_DOWNLOAD_TIMEOUT_MS=45000
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=
APIFY_YOUTUBE_ACTOR_ID=
APIFY_X_ACTOR_ID=
APIFY_TIMEOUT_MS=120000

# local keeps file storage only. hybrid writes local + SharePoint when configured. sharepoint requires Graph config.
STORAGE_PROVIDER=local
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_RUNS_LIST_ID=
SHAREPOINT_POSTS_LIST_ID=
SHAREPOINT_CAMPAIGNS_LIST_ID=
SHAREPOINT_RUNS_LIST_NAME=ASPI Content Pulse Runs
SHAREPOINT_POSTS_LIST_NAME=ASPI Content Pulse Posts
SHAREPOINT_CAMPAIGNS_LIST_NAME=ASPI Content Pulse Campaigns
